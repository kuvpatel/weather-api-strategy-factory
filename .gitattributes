# Auto detect text files and normalize line endings
* text=auto

# C# source files
*.cs text diff=csharp

# Solution and project files
*.sln text
*.csproj text
*.props text
*.targets text
*.json text
*.xml text
*.yml text
*.yaml text

# Scripts
*.ps1 text eol=crlf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary